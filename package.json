{
  "name": "momentbook-admin",
  "version": "1.3.0",
  "private": true,
  "packageManager": "yarn@3.6.4",
  "astryx": {
    "theme": "momentbook-admin"
  },
  "scripts": {
    "dev": "NODE_ENV=development next dev -p 3200",
    "build": "NODE_ENV=production next build",
    "start": "NODE_ENV=production next start -p 3200",
    "lint": "eslint",
    "generate:api": "yarn run generate:api:auth && yarn run generate:api:core && yarn run generate:api:chat",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "generate:api:auth": "npx swagger-typescript-api@13.1.3 generate -p http://10.133.199.134:8080/auth/swagger/json -o ./src/apis/auth -n client.ts",
    "generate:api:core": "npx swagger-typescript-api@13.1.3 generate -p http://10.133.199.134:8080/core/swagger/json -o ./src/apis/core -n client.ts",
    "generate:api:chat": "npx swagger-typescript-api@13.1.3 generate -p http://10.133.199.134:8080/chat/swagger/json -o ./src/apis/chat -n client.ts"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@stylexjs/stylex": "^0.18.3",
    "jose": "^6.2.2",
    "lucide-react": "1.8.0",
    "next": "16.1.1",
    "react": "19",
    "react-dom": "19",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.4",
    "@types/node": "^20",
    "@types/react": "19",
    "@types/react-dom": "19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "sass": "^1.97.1",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
