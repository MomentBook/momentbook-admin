# MomentBook Admin — Environment Variables
# =============================================================================
#
# Setup:
#   Local dev:  cp .env.example .env  → fill in values below
#   Production: set all variables in Vercel Dashboard >
#               Project Settings > Environment Variables (Production)
#
# =============================================================================

# -------- Required: URLs --------

# Admin site base URL (must be HTTPS in production unless APP_IS_LOCAL=true)
#   Dev:  http://localhost:3200
#   Prod: https://admin.momentbook.app
NEXT_PUBLIC_ADMIN_SITE_URL=

# Backend Nest API base URL
#   Dev:  http://127.0.0.1:3001
#   Prod: https://api.momentbook.app
NEXT_PUBLIC_API_BASE_URL=

# Public image CDN origin
#   Dev:  http://127.0.0.1:3001
#   Prod: https://d1mnbpnyxoksha.cloudfront.net
NEXT_PUBLIC_PUBLIC_IMAGE_ORIGIN=

# Web revalidation webhook URL
#   Dev:  http://localhost:3100/api/internal/revalidate
#   Prod: https://momentbook.app/api/internal/revalidate
WEB_REVALIDATION_URL=

# -------- Required: Runtime Flags --------

# Application environment: "development" | "production"
#   Dev:  development
#   Prod: production
NEXT_PUBLIC_APP_ENV=

# Allow localhost connection fallbacks: "true" | "false"
#   Dev:  true
#   Prod: false
NEXT_PUBLIC_APP_IS_LOCAL=

# -------- Required: Auth --------

# Allowed admin email for login
#   Dev:  admin@momentbook.app
#   Prod: admin@momentbook.app
ADMIN_ALLOWED_EMAIL=

# -------- Required: Secrets (keep out of version control) --------

# Encrypted admin cookie signing secret (64-char hex string recommended)
ADMIN_SESSION_SECRET=

# Shared HMAC secret for cache revalidation webhook
WEB_REVALIDATION_SECRET=
